<?php

/**
 * @file
 * Redeyed Sentinel CAPTCHA.
 *
 * Adds a Redeyed Sentinel human-verification widget to the user login and
 * registration forms and verifies the result server-side.
 *
 * Sentinel contract:
 *  - Render: load "{base_url}/sentinel.js" once and place a
 *    <div class="sentinel-captcha" data-sitekey="{site_key}"></div> in the
 *    form. The widget injects a hidden "sentinel-token" input.
 *  - Verify: POST "{base_url}/sentinel/siteverify" with JSON body
 *    {"secret": "...", "response": "...", "remoteip": "..."} (remoteip
 *    optional). Passes only when the JSON has success === true.
 *
 * Free to install: when the site key or secret key is empty the widget renders
 * nothing and verification fails OPEN, so forms are never blocked.
 */

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Render\Markup;
use GuzzleHttp\Exception\GuzzleException;

/**
 * Forms that receive the Sentinel widget.
 */
const REDEYED_CAPTCHA_FORMS = [
  'user_login_form',
  'user_register_form',
];

/**
 * Implements hook_form_alter().
 */
function redeyed_sentinel_form_alter(array &$form, FormStateInterface $form_state, $form_id) {
  if (!in_array($form_id, REDEYED_CAPTCHA_FORMS, TRUE)) {
    return;
  }

  $config = \Drupal::config('redeyed_sentinel.settings');
  $site_key = trim((string) $config->get('site_key'));
  $base_url = rtrim(trim((string) $config->get('base_url')) ?: 'https://redeyed.com', '/');

  // Optional widget customization. Each renders as a data-* attribute only
  // when non-empty (see the inline template below).
  $widget = trim((string) $config->get('widget'));
  $theme = trim((string) $config->get('theme'));
  $scheme = trim((string) $config->get('scheme'));
  $difficulty = trim((string) $config->get('difficulty'));
  $width = trim((string) $config->get('width'));

  // Inert: no site key configured -> render nothing, add no validation.
  if ($site_key === '') {
    return;
  }

  // Render the loader script (once) and the captcha mount point.
  // Twig autoescaping in the inline template escapes every value below.
  $form['redeyed_sentinel_captcha'] = [
    '#type' => 'container',
    '#weight' => 100,
    'widget' => [
      '#type' => 'inline_template',
      '#template' => '<script src="{{ script_src }}" async></script><div class="sentinel-captcha" data-sitekey="{{ site_key }}"{% if widget %} data-widget="{{ widget }}"{% endif %}{% if theme %} data-theme="{{ theme }}"{% endif %}{% if scheme %} data-scheme="{{ scheme }}"{% endif %}{% if difficulty %} data-difficulty="{{ difficulty }}"{% endif %}{% if width %} data-width="{{ width }}"{% endif %}></div>',
      '#context' => [
        'script_src' => $base_url . '/sentinel.js',
        'site_key' => $site_key,
        'widget' => $widget,
        'theme' => $theme,
        'scheme' => $scheme,
        'difficulty' => $difficulty,
        'width' => $width,
      ],
    ],
  ];

  // Server-side verification runs before the form's own validation handlers.
  array_unshift($form['#validate'], 'redeyed_sentinel_validate');
}

/**
 * Form validation handler: verifies the Sentinel token server-side.
 */
function redeyed_sentinel_validate(array &$form, FormStateInterface $form_state) {
  $config = \Drupal::config('redeyed_sentinel.settings');
  $site_key = trim((string) $config->get('site_key'));
  $secret_key = trim((string) $config->get('secret_key'));
  $base_url = rtrim(trim((string) $config->get('base_url')) ?: 'https://redeyed.com', '/');

  // Fail OPEN when keys are not fully configured.
  if ($site_key === '' || $secret_key === '') {
    return;
  }

  // sentinel.js injects the token as a raw POST field "sentinel-token";
  // it is not part of Drupal's Form API tree, so read it from the request.
  $request = \Drupal::request();
  $token = trim((string) $request->request->get('sentinel-token', ''));

  $failure = t('Human verification failed — please try again.');

  if ($token === '') {
    $form_state->setErrorByName('redeyed_sentinel_captcha', $failure);
    return;
  }

  $remote_ip = (string) $request->getClientIp();

  if (!redeyed_sentinel_verify($base_url, $secret_key, $token, $remote_ip)) {
    $form_state->setErrorByName('redeyed_sentinel_captcha', $failure);
  }
}

/**
 * Verifies a Sentinel token against the Redeyed siteverify endpoint.
 *
 * Uses the reCAPTCHA/Turnstile-style flow: the site's own secret key
 * authenticates the request (there is no developer API key).
 *
 * @param string $base_url
 *   Sentinel base URL, no trailing slash.
 * @param string $secret_key
 *   The site's secret key (sent only in the POST body, never logged/echoed).
 * @param string $token
 *   The submitted sentinel-token value.
 * @param string $remote_ip
 *   The client IP address (optional; sent as "remoteip" when non-empty).
 *
 * @return bool
 *   TRUE only when the response reports success; FALSE on failure or error.
 */
function redeyed_sentinel_verify(string $base_url, string $secret_key, string $token, string $remote_ip = ''): bool {
  $payload = [
    'secret' => $secret_key,
    'response' => $token,
  ];
  if ($remote_ip !== '') {
    $payload['remoteip'] = $remote_ip;
  }

  try {
    $response = \Drupal::httpClient()->post($base_url . '/sentinel/siteverify', [
      'headers' => [
        'Content-Type' => 'application/json',
        'Accept' => 'application/json',
      ],
      'json' => $payload,
      'timeout' => 10,
      'http_errors' => FALSE,
    ]);

    $data = json_decode((string) $response->getBody(), TRUE);
  }
  catch (GuzzleException $e) {
    // Network/transport failure: treat as not verified. Do not log the key.
    \Drupal::logger('redeyed_sentinel')->warning('Sentinel verification request failed: @msg', [
      '@msg' => $e->getMessage(),
    ]);
    return FALSE;
  }

  if (!is_array($data)) {
    return FALSE;
  }

  // Pass only when the response reports success === true.
  return isset($data['success']) && $data['success'] === TRUE;
}
